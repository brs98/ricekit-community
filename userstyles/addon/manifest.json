{
  "manifest_version": 2,
  "name": "Ricekit Userstyles",
  "version": "0.1.0",
  "description": "Live :root CSS variable updates for Catppuccin userstyles, driven by ricekit theme changes",
  "permissions": ["nativeMessaging"],
  "browser_specific_settings": {
    "gecko": {
      "id": "ricekit-userstyles@ricekit.dev",
      "strict_min_version": "102.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "experiment_apis": {
    "sheet": {
      "schema": "schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["sheet"]],
        "script": "api.js"
      }
    }
  }
}
